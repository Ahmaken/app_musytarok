{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/pairing/layout,_N_T_/dashboard/pairing/page,_N_T_/dashboard/pairing"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/pairing/__PAGE__",
    "/dashboard/pairing",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}